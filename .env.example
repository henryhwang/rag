# ============================================
# Environment Configuration Template
# ============================================
# 
# Copy this file to .env (DO NOT commit .env to git!)
# Fill in your actual values below.
# 
# For development/testing without API keys, run with mock embeddings:
#   bun examples/load-markdown-to-sqlite.ts
# 
# For production with real embeddings:
#   USE_REAL_EMBEDDINGS=true bun examples/load-markdown-to-sqlite.ts
# 
# See examples/basic.ts for demonstration of mock components

# ============================================
# REAL EMBEDDINGS: Set this to 'true' to use OpenAI API
# Otherwise the example uses mock embeddings (no API calls needed)
# ============================================
USE_REAL_EMBEDDINGS=true

# ============================================
# OPENAI-COMPATIBLE EMBEDDINGS
# Required when USE_REAL_EMBEDDINGS=true
# ============================================
# Your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_embedding_api_key_here

# Base URL (OpenAI, Azure, or compatible provider)
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# Embedding model name
# Options:
#   - text-embedding-3-small  (1536 dimensions) - recommended for most use cases
#   - text-embedding-3-large  (3072 dimensions) - better quality, higher cost
#   - text-embedding-ada-002  (1536 dimensions) - legacy model
OPENAI_MODEL=BAAI/bge-reranker-v2-m3

# Dimension count for the chosen model
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072  
# text-embedding-ada-002: 1536
OPENAI_EMBEDDING_DIMENSIONS=1024

# ============================================
# OPTIONAL: LLM Provider (for query answering)
# ============================================
# Only needed if using RAG.queryAndAnswer()
# Otherwise can remain unset
# LLM_API_KEY=your_llm_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
