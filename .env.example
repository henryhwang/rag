# Copy this file to .env and fill in your values
# This file contains example configurations for various AI providers

# OpenAI Compatible Providers
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=text-embedding-3-small

# Alternative: Ollama (local)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=nomic-embed-text

# Alternative: NVIDIA API
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_API_KEY=your-nvidia-api-key
# OPENAI_MODEL=nvolveqaai/embed-english-v3

# Alternative: ModelScope (China)
# OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
# OPENAI_API_KEY=your-modelscope-api-key
# OPENAI_MODEL=Qwen/Qwen3-Embedding-8B

# For testing/development, use Mock components instead of real API calls
# See examples/basic.ts for demonstration
