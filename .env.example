# ============================================
# Environment Configuration Template
# ============================================
# 
# Copy this file to .env (DO NOT commit .env to git!)
# Fill in your actual values below.
# 
# For development/testing without API keys, use Mock components:
# - MockEmbeddings instead of OpenAICompatibleEmbeddings
# - MockLLM instead of OpenAICompatibleLLM
# See examples/basic.ts for demonstration

# ============================================
# OPENAI-COMPATIBLE EMBEDDINGS
# ============================================
# Required for embedding text documents
OPENAI_API_KEY=your_embedding_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024  # Common: 1536 (text-embedding-3-large), 1024, 768

# ============================================
# OPTIONAL: LLM Provider (for query answering)
# ============================================
# Only needed if using RAG.queryAndAnswer()
# Otherwise can remain unset
# LLM_API_KEY=your_llm_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
